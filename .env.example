# Kast AI — environment variables
ENV=dev                                    # dev | prod
PORT=8000
WORKERS=1

# Optional: Bearer token auth (leave empty to disable)
KAST_API_KEY=

# Optional: CORS whitelist (comma-separated; use * for all — dev only)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: PostgreSQL (not required — defaults to in-memory store)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kast_forecast
